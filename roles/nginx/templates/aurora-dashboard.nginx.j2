{% if aurora_tls_available | default(false) | bool %}
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name {{ aurora_domain }};

    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_min_length 1024;
    gzip_types
        text/plain
        text/css
        text/javascript
        application/javascript
        application/json
        application/xml
        image/svg+xml;

    ssl_certificate /etc/letsencrypt/live/{{ aurora_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ aurora_domain }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location = / {
        return 302 /app;
    }

    location ^~ /mobile/v1/ {
        proxy_pass http://{{ aurora_mobile_api_host }}:{{ aurora_mobile_api_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering on;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }

    location /static/ {
        proxy_pass http://{{ aurora_panel_host }}:{{ aurora_panel_port }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering on;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
        expires 7d;
        add_header Cache-Control "public, max-age=604800, immutable" always;
    }

    location / {
        proxy_pass http://{{ aurora_panel_host }}:{{ aurora_panel_port }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    access_log /var/log/nginx/{{ aurora_domain }}_access.log;
    error_log /var/log/nginx/{{ aurora_domain }}_error.log warn;
}

server {
    listen 80;
    listen [::]:80;
    server_name {{ aurora_domain }};

    location = / {
        return 301 https://$host/app;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}
