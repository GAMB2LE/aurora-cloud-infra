#!/usr/bin/env bash
set -euo pipefail

source_user={{ vaisalamet_source_user | quote }}
source_host={{ vaisalamet_source_host | quote }}
source_port={{ vaisalamet_source_port | int }}
source_path={{ vaisalamet_source_path | quote }}
source_pattern={{ vaisalamet_source_pattern | quote }}
destination={{ vaisalamet_source_destination | quote }}
state_file={{ vaisalamet_source_state_file | quote }}
source_auth={{ vaisalamet_source_auth | default('tailscale') | quote }}
ssh_key={{ vaisalamet_source_ssh_key_path | quote }}
start_fresh={{ '1' if vaisalamet_source_start_fresh | bool else '0' }}
known_hosts=/home/{{ aurora_service_user }}/.ssh/known_hosts

mkdir -p "$destination" "$(dirname "$state_file")" "$(dirname "$known_hosts")"

if [[ ! -f "$state_file" ]]; then
  if [[ "$start_fresh" == "1" ]]; then
    date +%s > "$state_file"
    echo "Initialized fresh Vaisala met sync state at $(cat "$state_file"); no historical files pulled."
    exit 0
  fi
  echo 0 > "$state_file"
fi

last_epoch="$(cat "$state_file")"
now_epoch="$(date +%s)"
files_from="$(mktemp)"
trap 'rm -f "$files_from"' EXIT

if [[ "$source_auth" == "ssh_key" ]]; then
  if [[ ! -f "$ssh_key" ]]; then
    echo "Missing Vaisala met source SSH key: $ssh_key" >&2
    exit 1
  fi
  ssh_opts=(
    -p "$source_port"
    -i "$ssh_key"
    -o BatchMode=yes
    -o IdentitiesOnly=yes
    -o StrictHostKeyChecking=accept-new
    -o UserKnownHostsFile="$known_hosts"
  )
  rsync_ssh="ssh -p $source_port -i $ssh_key -o BatchMode=yes -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=$known_hosts"
else
  ssh_opts=(
    -p "$source_port"
    -o BatchMode=yes
    -o IdentitiesOnly=yes
    -o IdentityFile=none
    -o PubkeyAuthentication=no
    -o StrictHostKeyChecking=accept-new
    -o UserKnownHostsFile="$known_hosts"
  )
  rsync_ssh="ssh -p $source_port -o BatchMode=yes -o IdentitiesOnly=yes -o IdentityFile=none -o PubkeyAuthentication=no -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=$known_hosts"
fi

ssh "${ssh_opts[@]}" "${source_user}@${source_host}" bash -s -- "$source_path" "$source_pattern" "$last_epoch" "$now_epoch" > "$files_from" <<'REMOTE_FIND'
set -euo pipefail
source_path="$1"
source_pattern="$2"
last_epoch="$3"
now_epoch="$4"
cd "$source_path"
find . -maxdepth 1 -type f -name "$source_pattern" -newermt "@${last_epoch}" ! -newermt "@${now_epoch}" -printf '%P\0'
REMOTE_FIND

if [[ ! -s "$files_from" ]]; then
  echo "$now_epoch" > "$state_file"
  echo "No new Vaisala met files found."
  exit 0
fi

export RSYNC_RSH="$rsync_ssh"
rsync -a --partial --from0 --files-from="$files_from" "${source_user}@${source_host}:${source_path%/}/" "${destination%/}/"
echo "$now_epoch" > "$state_file"
