#!/usr/bin/env bash
set -euo pipefail

source_user={{ hatpro_source_user | quote }}
source_host={{ hatpro_source_host | quote }}
source_path={{ hatpro_source_path | quote }}
source_pattern={{ hatpro_source_pattern | quote }}
destination={{ hatpro_source_destination | quote }}
state_file={{ hatpro_source_state_file | quote }}
start_fresh={{ '1' if hatpro_source_start_fresh | bool else '0' }}
known_hosts=/home/{{ aurora_service_user }}/.ssh/known_hosts

mkdir -p "$destination" "$(dirname "$state_file")" "$(dirname "$known_hosts")"

if [[ ! -f "$state_file" ]]; then
  if [[ "$start_fresh" == "1" ]]; then
    date +%s > "$state_file"
    echo "Initialized fresh HATPRO sync state at $(cat "$state_file"); no historical files pulled."
    exit 0
  fi
  echo 0 > "$state_file"
fi

last_epoch="$(cat "$state_file")"
now_epoch="$(date +%s)"
files_from="$(mktemp)"
trap 'rm -f "$files_from"' EXIT

# Tailscale SSH handles authentication on the tailnet. Keep this as regular
# ssh so rsync can pass its normal remote-shell arguments, but disable identity
# keys to avoid falling back to file-based SSH authentication.
ssh_opts=(
  -o BatchMode=yes
  -o IdentitiesOnly=yes
  -o IdentityFile=none
  -o PubkeyAuthentication=no
  -o StrictHostKeyChecking=accept-new
  -o UserKnownHostsFile="$known_hosts"
)

ssh "${ssh_opts[@]}" "${source_user}@${source_host}" bash -s -- "$source_path" "$source_pattern" "$last_epoch" "$now_epoch" > "$files_from" <<'REMOTE_FIND'
set -euo pipefail
source_path="$1"
source_pattern="$2"
last_epoch="$3"
now_epoch="$4"
cd "$source_path"
find . -type f -name "$source_pattern" -newermt "@${last_epoch}" ! -newermt "@${now_epoch}" -printf '%P\0'
REMOTE_FIND

if [[ ! -s "$files_from" ]]; then
  echo "$now_epoch" > "$state_file"
  echo "No new HATPRO files found."
  exit 0
fi

export RSYNC_RSH="ssh -o BatchMode=yes -o IdentitiesOnly=yes -o IdentityFile=none -o PubkeyAuthentication=no -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=$known_hosts"
rsync -a --partial --from0 --files-from="$files_from" "${source_user}@${source_host}:${source_path%/}/" "${destination%/}/"
echo "$now_epoch" > "$state_file"
