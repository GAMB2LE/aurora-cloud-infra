#!/usr/bin/env bash
set -euo pipefail

source_user={{ wxcam_source_user | quote }}
source_host={{ wxcam_source_host | quote }}
source_path={{ wxcam_source_path | quote }}
destination={{ wxcam_source_destination | quote }}
known_hosts=/home/{{ aurora_service_user }}/.ssh/known_hosts
lock_file={{ aurora_state_root | quote }}/wxcam-sync.lock
ssh_opts=(
  -o BatchMode=yes
  -o ConnectTimeout=15
  -o IdentitiesOnly=yes
  -o IdentityFile=none
  -o PubkeyAuthentication=no
  -o ServerAliveInterval=15
  -o ServerAliveCountMax=4
  -o StrictHostKeyChecking=accept-new
  -o UserKnownHostsFile="$known_hosts"
)
rsync_base=(rsync -a --partial --timeout=120)

sync_target() {
  local source_suffix="$1"
  local destination_suffix="$2"
  mkdir -p "$destination/$destination_suffix"
  "${rsync_base[@]}" \
    -e "ssh ${ssh_opts[*]}" \
    "${source_user}@${source_host}:${source_path%/}/${source_suffix%/}/" \
    "${destination%/}/${destination_suffix%/}/"
}

mkdir -p "$destination" "$(dirname "$known_hosts")" "$(dirname "$lock_file")"

# The wxcam tree is large enough that overlapping rsync runs are more trouble
# than help. Exit cleanly if a previous timer run is still working.
exec 9>"$lock_file"
if ! flock -n 9; then
  echo "wxcam sync already running; exiting."
  exit 0
fi

mapfile -t priority_dirs < <(
  ssh "${ssh_opts[@]}" "${source_user}@${source_host}" "bash -s" <<'EOF'
set -euo pipefail
source_path="{{ wxcam_source_path }}"
for stream in FISH PANO; do
  find "${source_path}/${stream}" -mindepth 1 -maxdepth 1 -type d -name '20*' -printf '%f\n' | sort | tail -n 2 | while IFS= read -r day_dir; do
    [ -n "${day_dir}" ] || continue
    printf '%s/%s\n' "${stream}" "${day_dir}"
  done
done
EOF
)

for relative_dir in "${priority_dirs[@]}"; do
  [ -n "$relative_dir" ] || continue
  sync_target "$relative_dir" "$relative_dir"
done

sync_target "" ""
