#!/usr/bin/env bash
set -euo pipefail

source_user={{ asfs_logger_source_user | quote }}
source_host={{ asfs_logger_source_host | quote }}
source_port={{ asfs_logger_source_port | int }}
source_path={{ asfs_logger_source_path | quote }}
source_pattern={{ asfs_logger_source_pattern | quote }}
destination={{ asfs_logger_source_destination | quote }}
state_file={{ asfs_logger_source_state_file | quote }}
source_auth={{ asfs_logger_source_auth | default('tailscale') | quote }}
ssh_key={{ asfs_logger_source_ssh_key_path | quote }}
start_fresh={{ '1' if asfs_logger_source_start_fresh | bool else '0' }}
lookback_days={{ asfs_logger_source_lookback_days | int }}
known_hosts=/home/{{ aurora_service_user }}/.ssh/known_hosts

mkdir -p "$destination" "$(dirname "$state_file")" "$(dirname "$known_hosts")"

if [[ ! -f "$state_file" ]]; then
  if [[ "$start_fresh" == "1" ]]; then
    date +%s > "$state_file"
    echo "Initialized fresh ASFS sync state at $(cat "$state_file"); no historical files pulled."
    exit 0
  fi
  echo 0 > "$state_file"
fi

last_epoch="$(cat "$state_file")"
now_epoch="$(date +%s)"
lookback_epoch=$(( now_epoch - lookback_days * 86400 ))
scan_epoch="$last_epoch"
if (( last_epoch > lookback_epoch )); then
  scan_epoch="$lookback_epoch"
fi
files_from="$(mktemp)"
trap 'rm -f "$files_from"' EXIT

if [[ "$source_auth" == "ssh_key" ]]; then
  if [[ ! -f "$ssh_key" ]]; then
    echo "Missing ASFS logger source SSH key: $ssh_key" >&2
    exit 1
  fi
  ssh_opts=(
    -p "$source_port"
    -i "$ssh_key"
    -o BatchMode=yes
    -o IdentitiesOnly=yes
    -o StrictHostKeyChecking=accept-new
    -o UserKnownHostsFile="$known_hosts"
  )
  rsync_ssh="ssh -p $source_port -i $ssh_key -o BatchMode=yes -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=$known_hosts"
else
  ssh_opts=(
    -p "$source_port"
    -o BatchMode=yes
    -o IdentitiesOnly=yes
    -o IdentityFile=none
    -o PubkeyAuthentication=no
    -o StrictHostKeyChecking=accept-new
    -o UserKnownHostsFile="$known_hosts"
  )
  rsync_ssh="ssh -p $source_port -o BatchMode=yes -o IdentitiesOnly=yes -o IdentityFile=none -o PubkeyAuthentication=no -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=$known_hosts"
fi

ssh "${ssh_opts[@]}" "${source_user}@${source_host}" bash -s -- "$source_path" "$source_pattern" "$scan_epoch" "$now_epoch" {{ asfs_crd_min_stamp | quote }} > "$files_from" <<'REMOTE_FIND'
set -euo pipefail
source_path="$1"
source_pattern="$2"
scan_epoch="$3"
now_epoch="$4"
min_stamp="$5"
cd "$source_path"
find . -maxdepth 1 -type f -name "$source_pattern" -newermt "@${scan_epoch}" ! -newermt "@${now_epoch}" -printf '%P\0' |
  while IFS= read -r -d '' name; do
    stamp="${name##*_}"
    stamp="${stamp%.dat}"
    if [[ "$stamp" > "$min_stamp" || "$stamp" == "$min_stamp" ]]; then
      printf '%s\0' "$name"
    fi
  done
REMOTE_FIND

if [[ ! -s "$files_from" ]]; then
  echo "$now_epoch" > "$state_file"
  echo "No new ASFS source files found."
  exit 0
fi

export RSYNC_RSH="$rsync_ssh"
rsync -a --partial --from0 --files-from="$files_from" "${source_user}@${source_host}:${source_path%/}/" "${destination%/}/"
echo "$now_epoch" > "$state_file"
