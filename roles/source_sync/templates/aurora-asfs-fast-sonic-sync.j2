#!/usr/bin/env bash
set -euo pipefail

source_user={{ asfs_fast_sonic_source_user | quote }}
source_host={{ asfs_fast_sonic_source_host | quote }}
source_path={{ asfs_fast_sonic_source_path | quote }}
source_pattern={{ asfs_fast_sonic_source_pattern | quote }}
destination={{ asfs_fast_sonic_source_destination | quote }}
state_file={{ asfs_fast_sonic_source_state_file | quote }}
start_fresh={{ '1' if asfs_fast_sonic_source_start_fresh | bool else '0' }}
lookback_days={{ asfs_fast_sonic_source_lookback_days | int }}
known_hosts=/home/{{ aurora_service_user }}/.ssh/known_hosts

mkdir -p "$destination" "$(dirname "$state_file")" "$(dirname "$known_hosts")"

if [[ ! -f "$state_file" ]]; then
  if [[ "$start_fresh" == "1" ]]; then
    date +%s > "$state_file"
    echo "Initialized fresh ASFS fast-sonic sync state at $(cat "$state_file"); no historical files pulled."
    exit 0
  fi
  echo 0 > "$state_file"
fi

last_epoch="$(cat "$state_file")"
now_epoch="$(date +%s)"
lookback_epoch=$(( now_epoch - lookback_days * 86400 ))
scan_epoch="$last_epoch"
if (( last_epoch > lookback_epoch )); then
  scan_epoch="$lookback_epoch"
fi
files_from="$(mktemp)"
trap 'rm -f "$files_from"' EXIT

# Tailscale SSH handles authentication on the tailnet. Keep this as regular
# ssh so rsync can pass its normal remote-shell arguments, but disable identity
# keys to avoid falling back to file-based SSH authentication.
ssh_opts=(
  -o BatchMode=yes
  -o IdentitiesOnly=yes
  -o IdentityFile=none
  -o PubkeyAuthentication=no
  -o StrictHostKeyChecking=accept-new
  -o UserKnownHostsFile="$known_hosts"
)

ssh "${ssh_opts[@]}" "${source_user}@${source_host}" bash -s -- "$source_path" "$scan_epoch" "$now_epoch" {{ asfs_crd_min_stamp | quote }} > "$files_from" <<'REMOTE_FIND'
set -euo pipefail
source_path="$1"
scan_epoch="$2"
now_epoch="$3"
min_stamp="$4"
source_pattern={{ asfs_fast_sonic_source_pattern | quote }}
cd "$source_path"
find . -maxdepth 1 -type f -name "$source_pattern" -newermt "@${scan_epoch}" ! -newermt "@${now_epoch}" -printf '%P\0' |
  while IFS= read -r -d '' name; do
    stamp="${name##*_}"
    stamp="${stamp%.dat}"
    if [[ "$stamp" > "$min_stamp" || "$stamp" == "$min_stamp" ]]; then
      printf '%s\0' "$name"
    fi
  done
REMOTE_FIND

if [[ ! -s "$files_from" ]]; then
  echo "$now_epoch" > "$state_file"
  echo "No new ASFS fast-sonic files found."
  exit 0
fi

export RSYNC_RSH="ssh -o BatchMode=yes -o IdentitiesOnly=yes -o IdentityFile=none -o PubkeyAuthentication=no -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=$known_hosts"
rsync -a --partial --from0 --files-from="$files_from" "${source_user}@${source_host}:${source_path%/}/" "${destination%/}/"
echo "$now_epoch" > "$state_file"
