#!/usr/bin/env bash
set -euo pipefail

source_user={{ cl61_source_user | quote }}
source_host={{ cl61_source_host | quote }}
source_path={{ cl61_source_path | quote }}
source_pattern={{ cl61_source_pattern | quote }}
destination={{ cl61_source_destination | quote }}
state_file={{ cl61_source_state_file | quote }}
ssh_key={{ cl61_source_ssh_key_path | quote }}
start_fresh={{ '1' if cl61_source_start_fresh | bool else '0' }}
known_hosts=/home/{{ aurora_service_user }}/.ssh/known_hosts

mkdir -p "$destination" "$(dirname "$state_file")"

if [[ ! -f "$ssh_key" ]]; then
  echo "Missing CL61 source SSH key: $ssh_key" >&2
  exit 1
fi

if [[ ! -f "$known_hosts" ]]; then
  echo "Missing CL61 source known_hosts file: $known_hosts" >&2
  exit 1
fi

if [[ ! -f "$state_file" ]]; then
  if [[ "$start_fresh" == "1" ]]; then
    date +%s > "$state_file"
    echo "Initialized fresh CL61 sync state at $(cat "$state_file"); no historical files pulled."
    exit 0
  fi
  echo 0 > "$state_file"
fi

last_epoch="$(cat "$state_file")"
now_epoch="$(date +%s)"
files_from="$(mktemp)"
trap 'rm -f "$files_from"' EXIT

ssh_opts=(
  -i "$ssh_key"
  -o BatchMode=yes
  -o IdentitiesOnly=yes
  -o StrictHostKeyChecking=yes
  -o UserKnownHostsFile="$known_hosts"
)

ssh "${ssh_opts[@]}" "${source_user}@${source_host}" bash -s -- "$source_path" "$source_pattern" "$last_epoch" "$now_epoch" > "$files_from" <<'REMOTE_FIND'
set -euo pipefail
source_path="$1"
source_pattern="$2"
last_epoch="$3"
now_epoch="$4"
cd "$source_path"
find . -maxdepth 1 -type f -name "$source_pattern" -newermt "@${last_epoch}" ! -newermt "@${now_epoch}" -printf '%P\0'
REMOTE_FIND

if [[ ! -s "$files_from" ]]; then
  echo "$now_epoch" > "$state_file"
  echo "No new CL61 files found."
  exit 0
fi

export RSYNC_RSH="ssh -i $ssh_key -o BatchMode=yes -o IdentitiesOnly=yes -o StrictHostKeyChecking=yes -o UserKnownHostsFile=$known_hosts"
rsync -a --partial --from0 --files-from="$files_from" "${source_user}@${source_host}:${source_path%/}/" "${destination%/}/"
echo "$now_epoch" > "$state_file"
