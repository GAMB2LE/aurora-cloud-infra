#!/usr/bin/env bash
set -euo pipefail

# This is the priority lane.  It only transfers recent frames, and has an
# independent checkpoint from the archive backfill so the dashboard remains
# live while historical recovery is in progress.
source_user={{ auroracam_source_user | quote }}
source_host={{ auroracam_source_host | quote }}
source_path={{ auroracam_source_path | quote }}
destination={{ auroracam_source_destination | quote }}
state_file={{ auroracam_source_state_file | quote }}
bootstrap_lookback_seconds={{ auroracam_source_bootstrap_lookback_seconds | int }}
overlap_seconds={{ auroracam_source_overlap_seconds | int }}
mtime_grace_seconds={{ auroracam_source_mtime_grace_seconds | int }}
known_hosts=/home/{{ aurora_service_user }}/.ssh/known_hosts
lock_file={{ aurora_state_root | quote }}/auroracam-live-sync.lock
ssh_opts=(
  -o BatchMode=yes
  -o ConnectTimeout=15
  -o IdentitiesOnly=yes
  -o IdentityFile=none
  -o PubkeyAuthentication=no
  -o ServerAliveInterval=15
  -o ServerAliveCountMax=4
  -o StrictHostKeyChecking=accept-new
  -o UserKnownHostsFile="$known_hosts"
)

mkdir -p "$destination" "$(dirname "$state_file")" "$(dirname "$known_hosts")" "$(dirname "$lock_file")"

exec 9>"$lock_file"
if ! flock -n 9; then
  echo "AURORACam priority sync already running; exiting."
  exit 0
fi

now_epoch="$(date +%s)"
if [[ -f "$state_file" ]] && [[ "$(cat "$state_file")" =~ ^[0-9]+$ ]]; then
  last_epoch="$(cat "$state_file")"
else
  last_epoch=$(( now_epoch - bootstrap_lookback_seconds ))
fi
scan_epoch=$(( last_epoch - overlap_seconds ))
if (( scan_epoch < 0 )); then
  scan_epoch=0
fi

files_from="$(mktemp)"
trap 'rm -f "$files_from"' EXIT

ssh "${ssh_opts[@]}" "${source_user}@${source_host}" bash -s -- \
  "$source_path" "$scan_epoch" "$mtime_grace_seconds" > "$files_from" <<'REMOTE_FIND'
set -euo pipefail
source_path="$1"
scan_epoch="$2"
mtime_grace_seconds="$3"
cd "$source_path"
upper_epoch=$(( $(date +%s) - mtime_grace_seconds ))
find . -type f -name '*.jpg' \
  -newermt "@${scan_epoch}" ! -newermt "@${upper_epoch}" \
  -printf '%P\0'
REMOTE_FIND

if [[ -s "$files_from" ]]; then
  rsync -a --partial --timeout=120 --from0 --files-from="$files_from" \
    -e "ssh ${ssh_opts[*]}" \
    "${source_user}@${source_host}:${source_path%/}/" \
    "${destination%/}/"
fi

echo "$now_epoch" > "$state_file"
echo "AURORACam priority sync checkpoint advanced to $now_epoch."
