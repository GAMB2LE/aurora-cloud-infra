[Unit]
Description=Compare Earthkit and legacy ECMWF forecast decoding
After=network-online.target aurora-dev-live-pull.service
Wants=network-online.target

[Service]
Type=oneshot
User={{ aurora_service_user }}
Group={{ aurora_service_group }}
WorkingDirectory={{ aurora_app_dir }}
EnvironmentFile=/etc/aurora-dashboard.env
ExecStart={{ aurora_venv }}/bin/python ecmwf_forecast_provider.py --cache-dir {{ aurora_paths.products_power_ecmwf_solar_forecast }} --report {{ aurora_ecmwf_shadow_report_path }} --history {{ aurora_ecmwf_shadow_history_path }} --latitude {{ aurora_power_forecast_latitude | default(64.829694) }} --longitude {{ aurora_power_forecast_longitude | default(-23.248139) }}
Nice=10
TimeoutStartSec=600
