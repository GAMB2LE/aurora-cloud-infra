[Unit]
Description=Aurora wxcam daily mp4 and hourly thumbnail products
After=network-online.target aurora-wxcam-source-sync.service
Wants=network-online.target

[Service]
Type=oneshot
User={{ aurora_service_user }}
Group={{ aurora_service_group }}
WorkingDirectory={{ aurora_app_dir }}
EnvironmentFile=/etc/aurora-dashboard.env
ExecCondition=/usr/bin/test -d {{ aurora_paths.raw_wxcam }}
ExecStart={{ aurora_venv }}/bin/python build_wxcam_daily_videos.py --raw-root {{ aurora_paths.raw_wxcam }} --output-root {{ aurora_paths.products_wxcam_daily_videos }}
Nice=10
