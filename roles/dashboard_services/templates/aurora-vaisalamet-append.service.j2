[Unit]
Description=Aurora Vaisala met Zarr append
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User={{ aurora_service_user }}
Group={{ aurora_service_group }}
WorkingDirectory={{ aurora_app_dir }}
EnvironmentFile=/etc/aurora-dashboard.env
ExecStart={{ aurora_venv }}/bin/python append_new_vaisalamet_to_zarr.py --root {{ aurora_paths.raw_vaisalamet }} --zarr {{ aurora_zarr.vaisalamet }} --chunk-time 1200
Nice=10
