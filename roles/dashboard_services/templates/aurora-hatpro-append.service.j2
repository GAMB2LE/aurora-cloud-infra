[Unit]
Description=Aurora HATPRO radiometer Zarr append
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User={{ aurora_service_user }}
Group={{ aurora_service_group }}
WorkingDirectory={{ aurora_app_dir }}
EnvironmentFile=/etc/aurora-dashboard.env
ExecStart={{ aurora_venv }}/bin/python hatpro_to_zarr.py --root {{ aurora_paths.raw_hatpro }} --zarr {{ aurora_zarr.hatpro }} --chunk-time 600 --chunk-range 48
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=6
