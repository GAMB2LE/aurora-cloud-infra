[Unit]
Description=Aurora ASFS fast-sonic Zarr append
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User={{ aurora_service_user }}
Group={{ aurora_service_group }}
WorkingDirectory={{ aurora_app_dir }}
EnvironmentFile=/etc/aurora-dashboard.env
ExecStart={{ aurora_venv }}/bin/python append_new_asfs_fast_sonic_to_zarr.py --root {{ aurora_paths.raw_asfs_logger }} --zarr {{ aurora_zarr.asfs_fast_sonic }} --chunk-time 24000
Nice=10
