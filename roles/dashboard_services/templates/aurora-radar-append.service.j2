[Unit]
Description=Aurora cloud radar Zarr append
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User={{ aurora_service_user }}
Group={{ aurora_service_group }}
WorkingDirectory={{ aurora_app_dir }}
EnvironmentFile=/etc/aurora-dashboard.env
ExecStart={{ aurora_venv }}/bin/python append_new_cloud_radar_to_zarr.py --root {{ aurora_paths.raw_radar }} --zarr {{ aurora_zarr.cloud_radar }} --chunk-time 400
Nice=10
