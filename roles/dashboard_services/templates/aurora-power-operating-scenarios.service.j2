[Unit]
Description=Development learned APS operating states and SOC plans
After=aurora-dev-live-pull.service aurora-power-soc-planning-forecast.service
ConditionPathExists={{ aurora_zarr.power }}
ConditionPathExists={{ aurora_power_planning_forecast_path }}

[Service]
Type=oneshot
User={{ aurora_service_user }}
Group={{ aurora_service_group }}
WorkingDirectory={{ aurora_app_dir }}
EnvironmentFile=/etc/aurora-dashboard.env
ExecStart={{ aurora_venv }}/bin/python generate_power_operating_scenarios.py --power-zarr {{ aurora_zarr.power }} --pdu-zarr {{ aurora_zarr.pdu }} --forecast-zarr {{ aurora_power_planning_forecast_path }} --ensemble-zarr {{ aurora_zarr.power_soc_ensemble }} --state-output {{ aurora_power_operating_state_path }} --scenario-output {{ aurora_power_operating_scenarios_path }} --model-state {{ aurora_power_operating_model_state_path }} --bootstrap-state {{ aurora_paths.products_power }}/power_soc_forecast_state.json --recommendation-archive {{ aurora_power_operating_recommendations_path }} --planning-hours 240 --optimization-hours 96 --lookback-days 7
ExecStart={{ aurora_venv }}/bin/python generate_power_display_summary.py --power-zarr {{ aurora_zarr.power }} --asfs-logger-zarr {{ aurora_zarr.asfs_logger }} --pdu-zarr {{ aurora_zarr.pdu }} --forecast-zarr {{ aurora_zarr.power_soc_forecast }} --forecast-skill-zarr {{ aurora_zarr.power_soc_forecast_skill }} --hindcast-zarr {{ aurora_zarr.power_soc_hindcast }} --ensemble-forecast-zarr {{ aurora_zarr.power_soc_ensemble }} --ensemble-skill-zarr {{ aurora_zarr.power_soc_ensemble_skill }} --operating-scenarios-zarr {{ aurora_power_operating_scenarios_path }} --output-zarr {{ aurora_power_display_summary_path }} --energy-output-zarr {{ aurora_power_display_energy_path }}
Nice=10
TimeoutStartSec=900
